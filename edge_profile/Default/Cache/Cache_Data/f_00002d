tag.hard { color: #ef4444; background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.15); }\n\n.problem-option-card h4 {\n  font-family: var(--font-display);\n  font-size: 16px;\n  font-weight: 800;\n  margin-bottom: 6px;\n}\n\n.problem-option-card p {\n  font-size: 12.5px;\n  color: var(--text-secondary);\n  line-height: 1.4;\n}\n\n.sandbox-workspace {\n  background: var(--bg-card);\n  backdrop-filter: blur(20px);\n  border: 1px solid var(--border-color);\n  border-radius: 24px;\n  padding: 32px;\n  display: flex;\n  flex-direction: column;\n  gap: 28px;\n}\n\n.sandbox-header-bar {\n  border-bottom: 1px solid rgba(255, 255, 255, 0.04);\n  padding-bottom: 16px;\n}\n\n.output-tabs {\n  display: flex;\n  gap: 8px;\n}\n\n.out-tab {\n  background: transparent;\n  border: 1px solid transparent;\n  color: var(--text-secondary);\n  padding: 8px 16px;\n  font-size: 13px;\n  font-weight: 600;\n  border-radius: 8px;\n  cursor: pointer;\n  transition: var(--transition-fast);\n}\n\n.out-tab:hover {\n  background-color: rgba(255, 255, 255, 0.03);\n  color: var(--text-primary);\n}\n\n.out-tab.active {\n  color: var(--color-ai);\n  background-color: rgba(139, 92, 246, 0.05);\n  border-color: rgba(139, 92, 246, 0.15);\n}\n\n.sandbox-console {\n  background: #020204;\n  border: 1px solid rgba(255, 255, 255, 0.03);\n  border-radius: 18px;\n  display: flex;\n  flex-direction: column;\n  height: 480px;\n  overflow: hidden;\n  position: relative;\n}\n\n.console-progress-container {\n  width: 100%;\n  height: 3px;\n  background: rgba(255, 255, 255, 0.03);\n  position: relative;\n  z-index: 15;\n}\n\n.console-progress-bar {\n  height: 100%;\n  width: 0%;\n  background: linear-gradient(90deg, var(--color-ai), var(--color-accepted));\n  transition: width 0.15s ease;\n}\n\n.console-context-bar {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 8px 24px;\n  background: rgba(9, 11, 16, 0.85);\n  backdrop-filter: blur(12px);\n  -webkit-backdrop-filter: blur(12px);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.04);\n  font-size: 11px;\n  color: var(--text-secondary);\n  font-family: var(--font-body);\n  font-weight: 600;\n  letter-spacing: 0.5px;\n  z-index: 12;\n  transition: opacity 0.3s ease, height 0.3s ease, padding 0.3s ease;\n  opacity: 0;\n  height: 0;\n  overflow: hidden;\n  pointer-events: none;\n}\n\n.console-context-bar.visible {\n  opacity: 1;\n  height: auto;\n  padding: 8px 24px;\n  pointer-events: auto;\n}\n\n.context-divider {\n  color: rgba(255, 255, 255, 0.15);\n}\n\n.console-main-layout {\n  display: flex;\n  flex: 1;\n  overflow: hidden;\n  position: relative;\n}\n\n.console-body {\n  flex: 1;\n  padding: 24px;\n  overflow-y: auto;\n  font-family: var(--font-body);\n  font-size: 13px;\n  line-height: 1.6;\n  color: #cbd5e1;\n  scroll-behavior: smooth;\n}\n\n.console-body::-webkit-scrollbar {\n  width: 6px;\n}\n\n.console-body::-webkit-scrollbar-track {\n  background: rgba(0, 0, 0, 0.2);\n}\n\n.console-body::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.06);\n  border-radius: 3px;\n}\n\n.console-body::-webkit-scrollbar-thumb:hover {\n  background: rgba(255, 255, 255, 0.15);\n}\n\n.console-toc {\n  width: 120px;\n  border-left: 1px solid rgba(255, 255, 255, 0.04);\n  padding: 16px 8px;\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n  background-color: rgba(2, 2, 4, 0.2);\n  font-size: 10px;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  user-select: none;\n  overflow-y: auto;\n}\n\n.toc-item {\n  color: var(--text-secondary);\n  text-decoration: none;\n  padding: 6px 8px;\n  border-radius: 6px;\n  transition: var(--transition-fast);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  opacity: 0.5;\n  pointer-events: none; /* Disabled until compiled */\n}\n\n.toc-item.enabled {\n  opacity: 0.8;\n  pointer-events: auto;\n}\n\n.toc-item:hover {\n  background: rgba(255, 255, 255, 0.03);\n  color: var(--text-primary);\n  opacity: 1;\n}\n\n.toc-item.active {\n  color: var(--color-ai);\n  background: rgba(139, 92, 246, 0.08);\n  font-weight: 700;\n  opacity: 1;\n}\n\n.console-story-section {\n  padding: 20px 0;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.03);\n  scroll-margin-top: 35px;\n  transition: opacity 0.4s ease, transform 0.4s ease;\n}\n\n.console-story-section.hidden-section {\n  display: none !important;\n}\n\n.console-story-section:last-child {\n  border-bottom: none;\n}\n\n.story-sec-title {\n  font-family: var(--font-display);\n  font-size: 13px;\n  font-weight: 800;\n  color: #ffffff;\n  margin-bottom: 12px;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.story-sec-title .sec-num {\n  color: var(--color-ai);\n  opacity: 0.8;\n}\n\n.story-card-wrapper {\n  background: rgba(255, 255, 255, 0.015);\n  border: 1px solid rgba(255, 255, 255, 0.03);\n  border-radius: 12px;\n  padding: 16px;\n  margin-top: 8px;\n}\n\n/* Section 1: Overview Styles */\n\n.overview-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 12px;\n}\n\n.overview-stat {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.overview-stat-lbl {\n  font-size: 9px;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.overview-stat-val {\n  font-size: 13px;\n  font-weight: 700;\n  color: #ffffff;\n}\n\n.overview-companies {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 6px;\n  margin-top: 8px;\n  grid-column: span 2;\n}\n\n.company-badge {\n  background: rgba(255, 255, 255, 0.02);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n  color: var(--text-secondary);\n  font-size: 10px;\n  font-weight: 600;\n  padding: 3px 8px;\n  border-radius: 6px;\n}\n\n/* Section 3: Pattern Flow chart */\n\n.pattern-flow-chart {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  align-items: center;\n  padding: 8px 0;\n}\n\n.flow-node {\n  background: rgba(255, 255, 255, 0.02);\n  border: 1px solid rgba(255, 255, 255, 0.04);\n  border-radius: 8px;\n  padding: 8px 14px;\n  width: 90%;\n  text-align: center;\n  font-size: 11.5px;\n  font-weight: 600;\n  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);\n}\n\n.flow-node.active-node {\n  border-color: var(--color-ai);\n  background: rgba(139, 92, 246, 0.04);\n  color: #ffffff;\n}\n\n.flow-arrow {\n  color: rgba(255, 255, 255, 0.15);\n  font-size: 10px;\n}\n\n/* Section 4: Complexity compare bars */\n\n.complexity-cards-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 12px;\n}\n\n.complexity-visual-card {\n  background: rgba(255, 255, 255, 0.015);\n  border: 1px solid rgba(255, 255, 255, 0.03);\n  border-radius: 12px;\n  padding: 12px;\n}\n\n.complexity-visual-card h5 {\n  font-size: 10px;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  margin-bottom: 8px;\n}\n\n.complexity-bar-wrapper {\n  margin-bottom: 8px;\n}\n\n.complexity-bar-label {\n  display: flex;\n  justify-content: space-between;\n  font-size: 10px;\n  margin-bottom: 3px;\n  color: var(--text-secondary);\n}\n\n.complexity-bar-outer {\n  height: 6px;\n  background: rgba(255, 255, 255, 0.04);\n  border-radius: 3px;\n  overflow: hidden;\n}\n\n.complexity-bar-inner {\n  height: 100%;\n  border-radius: 3px;\n  width: 0%;\n  transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.complexity-bar-inner.bad {\n  background: linear-gradient(90deg, #f59e0b, #ef4444);\n}\n\n.complexity-bar-inner.good {\n  background: linear-gradient(90deg, var(--color-analysis), var(--color-accepted));\n}\n\n/* Section 6: Code solution block with Line Numbers */\n\n.code-story-container {\n  position: relative;\n  border-radius: 12px;\n  border: 1px solid rgba(255, 255, 255, 0.04);\n  background: #020204;\n  overflow: hidden;\n}\n\n.code-story-header {\n  background: rgba(255, 255, 255, 0.01);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.04);\n  padding: 6px 12px;\n  font-size: 10.5px;\n  color: var(--text-muted);\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.code-story-viewport {\n  max-height: 250px;\n  overflow-y: auto;\n  transition: max-height 0.3s ease;\n}\n\n.code-story-viewport.collapsed {\n  max-height: 120px;\n}\n\n.code-line {\n  display: flex;\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 12px;\n  line-height: 1.6;\n  padding: 1px 16px;\n  transition: background 0.15s ease, color 0.15s ease;\n  cursor: pointer;\n}\n\n.code-line:hover, .code-line.active-hl {\n  background: rgba(139, 92, 246, 0.08);\n  color: #ffffff;\n}\n\n.code-line-num {\n  width: 24px;\n  color: rgba(255, 255, 255, 0.2);\n  user-select: none;\n  text-align: right;\n  padding-right: 8px;\n  border-right: 1px solid rgba(255, 255, 255, 0.03);\n}\n\n.code-line-content {\n  flex: 1;\n  padding-left: 8px;\n  white-space: pre;\n}\n\n.btn-expand-code {\n  background: transparent;\n  border: none;\n  color: var(--text-secondary);\n  font-size: 9.5px;\n  cursor: pointer;\n  font-weight: 600;\n  text-transform: uppercase;\n}\n\n/* Section 7: Execution Trace Debugger UI */\n\n.trace-container {\n  background: rgba(255, 255, 255, 0.01);\n  border: 1px solid rgba(255, 255, 255, 0.03);\n  border-radius: 12px;\n  padding: 12px;\n}\n\n.trace-controls {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  margin-bottom: 12px;\n}\n\n.trace-btn {\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid rgba(255, 255, 255, 0.06);\n  color: var(--text-primary);\n  padding: 4px 10px;\n  border-radius: 6px;\n  font-size: 10px;\n  font-weight: 600;\n  cursor: pointer;\n  transition: var(--transition-fast);\n}\n\n.trace-btn:hover {\n  background: var(--border-hover);\n}\n\n.trace-btn:disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n}\n\n.trace-scrubber-wrapper {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n.trace-slider {\n  flex: 1;\n  height: 4px;\n  -webkit-appearance: none;\n  background: rgba(255, 255, 255, 0.08);\n  border-radius: 2px;\n  outline: none;\n  cursor: pointer;\n}\n\n.trace-slider::-webkit-slider-thumb {\n  -webkit-appearance: none;\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  background: var(--color-ai);\n  box-shadow: 0 0 6px var(--color-ai);\n  transition: transform 0.1s ease;\n}\n\n.trace-slider::-webkit-slider-thumb:hover {\n  transform: scale(1.3);\n}\n\n.trace-step-badge {\n  font-size: 9px;\n  font-family: 'Courier New', Courier, monospace;\n  background: rgba(255, 255, 255, 0.04);\n  padding: 2px 4px;\n  border-radius: 4px;\n  color: var(--text-secondary);\n}\n\n.trace-visualizer {\n  background: #020204;\n  border: 1px solid rgba(255, 255, 255, 0.03);\n  border-radius: 8px;\n  padding: 12px;\n  min-height: 100px;\n  font-size: 11.5px;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.trace-viz-variables {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.03);\n  padding-bottom: 6px;\n}\n\n.trace-var {\n  font-family: 'Courier New', Courier, monospace;\n}\n\n.trace-var-name {\n  color: var(--color-analysis);\n}\n\n.trace-var-val {\n  color: #ffffff;\n  font-weight: 700;\n}\n\n.trace-viz-graphics {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  gap: 6px;\n  min-height: 40px;\n}\n\n.trace-log-msg {\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 11px;\n  color: var(--color-accepted);\n  text-align: center;\n}\n\n/* Section 8: Line-by-line explanation items */\n\n.explanation-story-list {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.exp-line {\n  border-left: 2px solid rgba(255, 255, 255, 0.04);\n  padding: 6px 12px;\n  transition: var(--transition-fast);\n  cursor: pointer;\n}\n\n.exp-line:hover, .exp-line.active-hl {\n  border-left-color: var(--color-ai);\n  background: rgba(139, 92, 246, 0.04);\n}\n\n.exp-line-header {\n  font-size: 10px;\n  font-weight: 700;\n  color: var(--color-analysis);\n  margin-bottom: 2px;\n  text-transform: uppercase;\n}\n\n.exp-line-body {\n  font-size: 12px;\n  color: var(--text-secondary);\n  line-height: 1.4;\n}\n\n/* Section 9: Edge Cases Validation */\n\n.edges-passes-list {\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n}\n\n.edge-pass-item {\n  display: grid;\n  grid-template-columns: 20px 1fr 100px;\n  align-items: center;\n  background: rgba(255, 255, 255, 0.01);\n  border: 1px solid rgba(255, 255, 255, 0.03);\n  border-radius: 8px;\n  padding: 6px 12px;\n}\n\n.edge-pass-check {\n  color: var(--color-accepted);\n  font-weight: bold;\n  font-size: 12px;\n}\n\n.edge-pass-input {\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 11px;\n  color: var(--text-secondary);\n}\n\n.edge-pass-result {\n  text-align: right;\n  font-size: 10px;\n  font-weight: 700;\n  color: var(--color-accepted);\n}\n\n/* Section 10: Common Mistakes warning cards */\n\n.mistakes-grid {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.mistake-warning-card {\n  background: rgba(239, 68, 68, 0.015);\n  border: 1px solid rgba(239, 68, 68, 0.08);\n  border-radius: 10px;\n  padding: 10px 14px;\n  display: flex;\n  gap: 10px;\n  align-items: flex-start;\n}\n\n.mistake-warning-card .warn-icon {\n  color: #ef4444;\n  font-weight: 900;\n  font-size: 14px;\n}\n\n.mistake-warning-card h5 {\n  font-size: 12px;\n  font-weight: 700;\n  color: #fca5a5;\n  margin-bottom: 2px;\n}\n\n.mistake-warning-card p {\n  font-size: 11px;\n  color: var(--text-secondary);\n  line-height: 1.4;\n}\n\n/* Section 11: Interview Follow-Ups */\n\n.followups-story-list {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.followup-story-item {\n  background: rgba(255, 255, 255, 0.01);\n  border: 1px solid rgba(255, 255, 255, 0.03);\n  border-radius: 8px;\n  padding: 10px 14px;\n}\n\n.followup-q {\n  font-size: 12px;\n  font-weight: 700;\n  color: var(--text-primary);\n  margin-bottom: 2px;\n}\n\n.followup-a {\n  font-size: 11.5px;\n  color: var(--text-secondary);\n  line-height: 1.4;\n}\n\n/* Section 12: Export Center */\n\n.export-options-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));\n  gap: 8px;\n}\n\n.export-btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: 4px;\n  background: rgba(255, 255, 255, 0.02);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n  color: var(--text-secondary);\n  padding: 8px;\n  border-radius: 8px;\n  font-size: 10px;\n  font-weight: 600;\n  cursor: pointer;\n  transition: var(--transition-fast);\n}\n\n.export-btn:hover {\n  background: var(--border-hover);\n  color: #ffffff;\n}\n\n/* Senior Engineer Intro Header Styling */\n\n.senior-intro-card {\n  border-left: 3px solid var(--color-ai);\n  background: linear-gradient(90deg, rgba(139, 92, 246, 0.03) 0%, transparent 100%);\n  padding: 14px 18px;\n  border-radius: 0 12px 12px 0;\n  margin-bottom: 16px;\n  animation: introFade 0.8s ease;\n}\n\n@keyframes introFade {\n  from { opacity: 0; transform: translateY(10px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n.senior-intro-card h3 {\n  font-family: var(--font-display);\n  font-size: 14px;\n  font-weight: 800;\n  color: #ffffff;\n  margin-bottom: 6px;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.senior-intro-card p {\n  font-size: 11.5px;\n  color: var(--text-secondary);\n  line-height: 1.4;\n  margin: 0;\n}\n\n.senior-intro-card strong {\n  color: var(--color-accepted);\n}\n\n.console-body p { margin-bottom: 12px; }\n\n.console-body table {\n  width: 100%;\n  border-collapse: collapse;\n  margin: 16px 0;\n  font-family: var(--font-body);\n  font-size: 12px;\n}\n\n.console-body th, .console-body td {\n  border: 1px solid rgba(255, 255, 255, 0.06);\n  padding: 8px 12px;\n  text-align: left;\n}\n\n.console-body th {\n  background: rgba(255, 255, 255, 0.02);\n  color: var(--text-secondary);\n}\n\n.console-action-bar {\n  height: 60px;\n  border-top: 1px solid rgba(255, 255, 255, 0.04);\n  background-color: rgba(255, 255, 255, 0.005);\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0 24px;\n}\n\n.console-status-label {\n  font-size: 12px;\n  color: var(--text-secondary);\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n.pulse-indicator {\n  width: 6px;\n  height: 6px;\n  background-color: var(--color-complexity);\n  border-radius: 50%;\n  display: inline-block;\n  box-shadow: 0 0 10px var(--color-complexity);\n  animation: pulseLight 1.5s infinite;\n}\n\n@keyframes pulseLight {\n  0% { transform: scale(1); opacity: 1; }\n  50% { transform: scale(1.4); opacity: 0.5; }\n  100% { transform: scale(1); opacity: 1; }\n}\n\n.console-status-label.solving .pulse-indicator {\n  background-color: var(--color-ai);\n  box-shadow: 0 0 10px var(--color-ai);\n}\n\n.console-status-label.done .pulse-indicator {\n  background-color: var(--color-accepted);\n  box-shadow: 0 0 10px var(--color-accepted);\n}\n\n.btn-run-solve {\n  padding: 8px 18px !important;\n  font-size: 12.5px !important;\n  border-radius: 12px !important;\n}\n\n.btn-copy {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  background-color: rgba(255, 255, 255, 0.015);\n  border: 1px solid var(--border-color);\n  border-radius: 8px;\n  color: var(--text-secondary);\n  font-size: 11px;\n  font-weight: 600;\n  padding: 6px 12px;\n  cursor: pointer;\n  transition: var(--transition-fast);\n}\n\n.btn-copy:hover {\n  background-color: var(--border-hover);\n  color: var(--text-primary);\n}\n\n.btn-copy.copied {\n  color: var(--color-accepted);\n  border-color: rgba(34, 197, 94, 0.3);\n  background-color: rgba(34, 197, 94, 0.05);\n}\n\n/* SECTION 5: ALGORITHM PATTERN SHOWCASE (HORIZONTAL PINNED SCROLL) */\n\n#showcase-sec {\n  padding: 0;\n}\n\n.showcase-pin-wrap {\n  display: flex;\n  flex-wrap: nowrap;\n  width: 500vw; /* 5 panels total */\n  height: 100vh;\n  align-items: center;\n}\n\n.showcase-panel {\n  width: 100vw;\n  height: 100vh;\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 0 60px;\n}\n\n.panel-intro {\n  max-width: 900px;\n  margin: 0 auto;\n  text-align: center;\n}\n\n.panel-header-desc {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 20px;\n}\n\n.panel-header-desc h2 {\n  font-family: var(--font-display);\n  font-size: 48px;\n  font-weight: 900;\n  letter-spacing: -1.5px;\n}\n\n.panel-header-desc p {\n  font-size: 17px;\n  color: var(--text-secondary);\n  max-width: 500px;\n  line-height: 1.6;\n}\n\n.showcase-card {\n  width: 100%;\n  max-width: 1050px;\n  height: 520px;\n  background-color: var(--card-glass);\n  backdrop-filter: blur(20px);\n  -webkit-backdrop-filter: blur(20px);\n  border: 1px solid var(--border-color);\n  border-radius: 28px;\n  padding: 48px;\n  display: grid;\n  grid-template-columns: 1fr 1.2fr;\n  gap: 48px;\n  position: relative;\n  overflow: hidden;\n  transition: transform 0.1s ease-out;\n  transform-style: preserve-3d;\n}\n\n.card-glow {\n  position: absolute;\n  width: 300px;\n  height: 300px;\n  border-radius: 50%;\n  filter: blur(90px);\n  top: -100px;\n  right: -100px;\n  opacity: 0.1;\n  pointer-events: none;\n}\n\n.card-glow.bg-purple { background-color: var(--color-ai); }\n\n.card-glow.bg-cyan { background-color: var(--color-analysis); }\n\n.card-glow.bg-amber { background-color: var(--color-complexity); }\n\n.card-glow.bg-green { background-color: var(--color-accepted); }\n\n.card-left {\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  gap: 24px;\n  transform: translateZ(20px);\n}\n\n.card-left h3 {\n  font-family: var(--font-display);\n  font-size: 32px;\n  font-weight: 800;\n  letter-spacing: -0.8px;\n}\n\n.card-left p {\n  font-size: 15.5px;\n  line-height: 1.6;\n  color: var(--text-secondary);\n}\n\n.card-meta {\n  display: flex;\n  gap: 10px;\n}\n\n.card-meta span {\n  font-size: 10px;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  padding: 5px 12px;\n  border-radius: 12px;\n}\n\n.tag-purple { color: var(--color-ai); background-color: rgba(139, 92, 246, 0.08); border: 1px solid rgba(139, 92, 246, 0.15); }\n\n.tag-cyan { color: var(--color-analysis); background-color: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.15); }\n\n.tag-amber { color: var(--color-complexity); background-color: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.15); }\n\n.tag-green { color: var(--color-accepted); background-color: rgba(34, 197, 94, 0.08); border: 1px solid rgba(34, 197, 94, 0.15); }\n\n.card-right {\n  background-color: #020204;\n  border: 1px solid rgba(255, 255, 255, 0.03);\n  border-radius: 20px;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n  transform: translateZ(30px);\n  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);\n}\n\n.viz-header {\n  height: 48px;\n  padding: 0 20px;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.04);\n  font-size: 12px;\n  font-weight: 700;\n  color: var(--text-secondary);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.viz-container {\n  flex: 1;\n  padding: 24px;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  gap: 20px;\n  position: relative;\n  overflow: hidden;\n}\n\n/* MINI-VISUALIZER CORE STYLES */\n\n.array-flex {\n  display: flex;\n  gap: 8px;\n  justify-content: center;\n  align-items: center;\n}\n\n.array-node {\n  width: 34px;\n  height: 34px;\n  border-radius: 6px;\n  background-color: rgba(255, 255, 255, 0.02);\n  border: 1px solid var(--border-color);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: var(--font-display);\n  font-size: 14px;\n  font-weight: 700;\n  position: relative;\n  transition: var(--transition-fast);\n}\n\n.array-node.active-window {\n  border-color: var(--color-accepted);\n  background-color: rgba(34, 197, 94, 0.06);\n}\n\n.array-node.edge-window {\n  border-color: var(--color-analysis);\n  background-color: rgba(6, 182, 212, 0.12);\n}\n\n.array-node.left-pointer {\n  border-color: var(--color-ai);\n  background-color: rgba(139, 92, 246, 0.12);\n}\n\n.array-node.right-pointer {\n  border-color: var(--color-complexity);\n  background-color: rgba(245, 158, 11, 0.12);\n}\n\n.array-node.found-node {\n  border-color: var(--color-accepted);\n  background-color: var(--color-accepted);\n  color: var(--bg-dark);\n  box-shadow: 0 0 15px var(--color-accepted-glow);\n}\n\n.node-ptr-lbl {\n  position: absolute;\n  bottom: -16px;\n  font-size: 8px;\n  font-weight: 800;\n  text-transform: uppercase;\n}\n\n.ptr-purple { color: var(--color-ai); }\n\n.ptr-amber { color: var(--color-complexity); }\n\n.ptr-cyan { color: var(--color-analysis); }\n\n.viz-footer-bar {\n  display: flex;\n  gap: 16px;\n  font-size: 11.5px;\n  color: var(--text-secondary);\n  border-top: 1px solid rgba(255, 255, 255, 0.03);\n  width: 100%;\n  padding-top: 12px;\n  justify-content: center;\n  font-family: 'Courier New', Courier, monospace;\n}\n\n/* Tree nodes flow for BFS viz */\n\n.bfs-tree-flow {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n  align-items: center;\n  width: 100%;\n}\n\n.bfs-level {\n  display: flex;\n  gap: 28px;\n  justify-content: center;\n}\n\n.bfs-circle-node {\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  background-color: rgba(255, 255, 255, 0.02);\n  border: 1px solid var(--border-color);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 12px;\n  font-weight: 700;\n  font-family: var(--font-display);\n  transition: var(--transition-fast);\n}\n\n.bfs-circle-node.visited {\n  border-color: var(--color-analysis);\n  background-color: rgba(6, 182, 212, 0.08);\n}\n\n.bfs-circle-node.active-bfs {\n  border-color: var(--color-ai);\n  background-color: var(--color-ai);\n  color: #fff;\n  box-shadow: 0 0 12px var(--color-ai-glow);\n}\n\n/* DP Grid visualizer */\n\n.dp-grid-table {\n  display: grid;\n  grid-template-columns: repeat(5, 28px);\n  gap: 5px;\n  background-color: rgba(5, 5, 8, 0.4);\n  padding: 8px;\n  border-radius: 10px;\n  border: 1px solid rgba(255, 255, 255, 0.015);\n}\n\n.dp-table-cell {\n  width: 28px;\n  height: 28px;\n  border-radius: 5px;\n  background-color: rgba(255, 255, 255, 0.01);\n  border: 1px solid var(--border-color);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 10px;\n  font-weight: 700;\n  transition: var(--transition-fast);\n}\n\n.dp-table-cell.filled {\n  border-color: var(--color-accepted);\n  background-color: rgba(34, 197, 94, 0.06);\n  color: var(--color-accepted);\n}\n\n.dp-table-cell.calculating {\n  border-color: var(--color-ai);\n  background-color: rgba(139, 92, 246, 0.15);\n  box-shadow: 0 0 6px var(--color-ai-glow);\n}\n\n.dp-table-cell.dependency {\n  border-color: var(--color-analysis);\n  background-color: rgba(6, 182, 212, 0.15);\n}\n\n/* SECTION 8: VISUAL ARCHITECTURE SHOWCASE */\n\n.arch-container {\n  width: 100%;\n  max-width: 1050px;\n  margin: 0 auto;\n  position: relative;\n  z-index: 5;\n  height: 400px;\n}\n\n.arch-svg-canvas {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  pointer-events: none;\n  z-index: 1;\n}\n\n.arch-nodes-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  grid-template-rows: 1fr 1fr;\n  gap: 48px;\n  width: 100%;\n  height: 100%;\n  position: relative;\n  z-index: 2;\n}\n\n.arch-node-card {\n  background-color: var(--card-glass);\n  backdrop-filter: blur(15px);\n  -webkit-backdrop-filter: blur(15px);\n  border: 1px solid var(--border-color);\n  border-radius: 20px;\n  padding: 24px;\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  justify-content: center;\n  transition: var(--transition-smooth);\n}\n\n.arch-node-card:hover {\n  border-color: var(--border-hover);\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);\n  transform: translateY(-4px);\n}\n\n.arch-icon {\n  width: 40px;\n  height: 40px;\n  border-radius: 10px;\n  background-color: rgba(255, 255, 255, 0.02);\n  border: 1px solid var(--border-color);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--color-ai);\n}\n\n.arch-node-card h4 {\n  font-family: var(--font-display);\n  font-size: 16.5px;\n  font-weight: 800;\n  letter-spacing: -0.3px;\n}\n\n.arch-node-card p {\n  font-size: 12.5px;\n  line-height: 1.5;\n  color: var(--text-secondary);\n}\n\n/* SECTION 7: METRICS */\n\n#metrics-sec {\n  background-color: rgba(255, 255, 255, 0.005);\n  border-top: 1px solid rgba(255, 255, 255, 0.02);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.02);\n  padding: 80px 0;\n}\n\n.metrics-container {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 32px;\n  text-align: center;\n  z-index: 5;\n}\n\n.metric-item {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.metric-val {\n  font-family: var(--font-display);\n  font-size: 56px;\n  font-weight: 900;\n  line-height: 1;\n  background: linear-gradient(135deg, var(--color-ai) 0%, var(--color-cyan) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  letter-spacing: -2px;\n}\n\n.metric-lbl {\n  font-size: 12px;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 2px;\n  color: var(--text-muted);\n}\n\n/* SECTION 9: TESTIMONIALS */\n\n.testimonials-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 32px;\n  z-index: 5;\n}\n\n.testimonial-card {\n  background-color: var(--bg-card);\n  backdrop-filter: blur(20px);\n  border: 1px solid var(--border-color);\n  border-radius: 24px;\n  padding: 36px;\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n  gap: 24px;\n}\n\n.testimonial-card p {\n  font-size: 15.5px;\n  line-height: 1.65;\n  color: var(--text-primary);\n  font-style: italic;\n}\n\n.user-meta h5 {\n  font-family: var(--font-display);\n  font-size: 15px;\n  font-weight: 800;\n  margin-bottom: 2px;\n}\n\n.user-meta span {\n  font-size: 12px;\n  color: var(--text-muted);\n}\n\n/* SECTION 10: FINAL CTA & FOOTER */\n\n#footer {\n  width: 100%;\n  max-width: 1150px;\n  margin: 0 auto;\n  padding: 100px 24px 40px;\n  display: flex;\n  flex-direction: column;\n  gap: 80px;\n  position: relative;\n  z-index: 5;\n}\n\n.footer-cta-card {\n  background: linear-gradient(135deg, rgba(20, 16, 30, 0.75) 0%, rgba(9, 11, 16, 0.75) 100%);\n  border: 1px solid var(--border-color);\n  border-radius: 32px;\n  padding: 64px;\n  text-align: center;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 24px;\n  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);\n  position: relative;\n  overflow: hidden;\n}\n\n.footer-cta-card h2 {\n  font-family: var(--font-display);\n  font-size: 38px;\n  font-weight: 800;\n  letter-spacing: -1px;\n  background: linear-gradient(180deg, #ffffff 40%, rgba(255, 255, 255, 0.5) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n\n.footer-cta-card p {\n  font-size: 16px;\n  color: var(--text-secondary);\n  max-width: 500px;\n  line-height: 1.6;\n}\n\n.footer-actions {\n  display: flex;\n  gap: 16px;\n}\n\n.footer-bottom {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  border-top: 1px solid rgba(255, 255, 255, 0.03);\n  padding-top: 40px;\n  font-size: 13px;\n  color: var(--text-muted);\n}\n\n.footer-bottom a {\n  color: var(--text-muted);\n  text-decoration: none;\n  transition: var(--transition-fast);\n}\n\n.footer-bottom a:hover {\n  color: var(--color-ai);\n}\n\n/* PYTHON SYNTAX HIGHLIGHTING CLASSES */\n\n.hl-keyword { color: #f43f5e; font-weight: 600; }\n\n.hl-def { color: #3b82f6; font-weight: 600; }\n\n.hl-string { color: #10b981; }\n\n.hl-comment { color: #71717a; font-style: italic; }\n\n.hl-type { color: #f59e0b; }\n\n.hl-number { color: #06b6d4; }\n\n.hl-builtin { color: #a855f7; }\n\n/* REVEAL WORDS MASK */\n\n.reveal-wrapper {\n  overflow: hidden;\n  display: inline-block;\n  vertical-align: bottom;\n}\n\n.reveal-word {\n  display: inline-block;\n  transform: translateY(105%);\n}\n\n/* REDUCED MOTION ACCESSIBILITY COMPLIANT SUPPORT */\n\n@media (prefers-reduced-motion: reduce) {\n  .custom-cursor, .custom-cursor-follower {\n    display: none !important;\n  }\n  \n  .glow-orb {\n    animation: none !important;\n  }\n  \n  .floating-tag {\n    animation: none !important;\n    transform: none !important;\n  }\n  \n  html {\n    scroll-behavior: auto !important;\n  }\n  \n  * {\n    animation-delay: 0s !important;\n    animation-duration: 0s !important;\n    transition-duration: 0s !important;\n  }\n}\n\n/* RESPONSIVE LAYOUT MEDIA QUERIES */\n\n@media (max-width: 1024px) {\n  .hero-title { font-size: 54px; }\n  .showcase-card { grid-template-columns: 1fr; height: auto; gap: 32px; padding: 32px; }\n  .arch-nodes-grid { gap: 24px; }\n}\n\n@media (max-width: 768px) {\n  header { padding: 0 16px; width: calc(100% - 24px); }\n  nav { display: none; }\n  .hero-title { font-size: 40px; }\n  .browser-body { grid-template-columns: 1fr; height: auto; }\n  .mockup-sidebar { display: none; }\n  .timeline-node { grid-template-columns: 1fr; justify-items: center; gap: 16px; }\n  .timeline-node:nth-child(even) .node-content { text-align: left; }\n  .scroll-line-container { display: none; }\n  .sandbox-container { grid-template-columns: 1fr; }\n  .sandbox-sidebar { display: none; }\n  .showcase-pin-wrap { width: auto; height: auto; flex-direction: column; }\n  .showcase-panel { width: 100vw; height: auto; padding: 60px 20px; }\n  .showcase-panel.panel-intro { height: auto; }\n  .arch-nodes-grid { grid-template-columns: 1fr; height: auto; }\n  .arch-container { height: auto; }\n  .arch-svg-canvas { display: none; }\n  .metrics-container { grid-template-columns: 1fr 1fr; }\n  .testimonials-grid { grid-template-columns: 1fr; }\n  .footer-cta-card { padding: 48px 24px; }\n  .footer-cta-card h2 { font-s