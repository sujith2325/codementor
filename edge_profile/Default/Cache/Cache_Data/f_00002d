}\n\n.timeline-node {\n  width: 100%;\n  display: grid;\n  grid-template-columns: 80px 1fr;\n  align-items: center;\n  gap: 32px;\n  position: relative;\n}\n\n.timeline-node:nth-child(even) {\n  direction: rtl;\n}\n\n.timeline-node:nth-child(even) .node-content {\n  direction: ltr;\n  text-align: right;\n}\n\n.node-indicator {\n  width: 80px;\n  height: 80px;\n  border-radius: 50%;\n  background: #090b10;\n  border: 2px solid var(--border-color);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: var(--font-display);\n  font-size: 20px;\n  font-weight: 800;\n  box-shadow: 0 0 20px rgba(0, 0, 0, 0.8);\n  z-index: 5;\n  transition: var(--transition-smooth);\n}\n\n.node-indicator.border-purple { border-color: var(--color-ai); color: var(--color-ai); }\n\n.node-indicator.border-cyan { border-color: var(--color-analysis); color: var(--color-analysis); }\n\n.node-indicator.border-amber { border-color: var(--color-complexity); color: var(--color-complexity); }\n\n.node-indicator.border-green { border-color: var(--color-accepted); color: var(--color-accepted); }\n\n.node-content {\n  background: var(--bg-card);\n  backdrop-filter: blur(20px);\n  -webkit-backdrop-filter: blur(20px);\n  border: 1px solid var(--border-color);\n  border-radius: 20px;\n  padding: 28px 36px;\n  transition: var(--transition-smooth);\n}\n\n.node-content h4 {\n  font-family: var(--font-display);\n  font-size: 19px;\n  font-weight: 800;\n  margin-bottom: 8px;\n}\n\n.node-content p {\n  font-size: 14.5px;\n  line-height: 1.5;\n  color: var(--text-secondary);\n}\n\n.timeline-node.highlighted .node-indicator {\n  transform: scale(1.1);\n  box-shadow: 0 0 25px currentColor;\n}\n\n.timeline-node.highlighted .node-content {\n  border-color: var(--border-hover);\n  background: rgba(255, 255, 255, 0.05);\n}\n\n/* SECTION 4: INTERACTIVE SOLVER SANDBOX */\n\n.sandbox-container {\n  width: 100%;\n  display: grid;\n  grid-template-columns: 300px 1fr;\n  gap: 32px;\n  z-index: 5